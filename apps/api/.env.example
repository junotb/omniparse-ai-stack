# Omniparse AI Stack - API Environment
# .env.exampleěť„ .envëˇś ëłµě‚¬ í›„ ę°’ ě„¤ě •

# Application
APP_NAME=Omniparse AI API
DEBUG=false
API_V1_PREFIX=/api/v1

# Celery (Redisë§Ś ě‚¬ěš© - broker + result backend)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Redis
REDIS_URL=redis://localhost:6379/0

# OCR
OCR_ENGINE=easyocr
OCR_LANGUAGES=["ko","en"]

# Upload
UPLOAD_DIR=/tmp/omniparse_uploads

# Agent (LangChain / OpenAI)
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
